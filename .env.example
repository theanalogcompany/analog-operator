# Example env file for analog-operator.
# All operator-app env vars must be prefixed with EXPO_PUBLIC_ to be accessible at runtime.
# Copy this file to .env.local and fill the values below.

# Supabase project URL and anon (publishable) key. Required for auth (TAC-206).
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Base URL for the analog-guest operator API (TAC-258).
# Required when EXPO_PUBLIC_USE_FIXTURES is unset/false. If missing in live
# mode, lib/api/queue.ts returns NO_SESSION on every call.
EXPO_PUBLIC_API_BASE_URL=https://analog-guest.vercel.app

# Fixture-mode toggle. Strict-true (`=true`) routes lib/api/queue.ts and
# lib/realtime/queue-channel.ts to the in-memory fixture; anything else
# (unset, false, 0) goes live. Use during offline dev / storybook work; leave
# unset elsewhere.
# EXPO_PUBLIC_USE_FIXTURES=true
